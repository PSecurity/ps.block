<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="#FF05070A" />
            <stroke android:width="1dp" android:color="#FF1F2937" />
            <corners android:radius="1dp" />
        </shape>
    </item>

    <item android:id="@android:id/secondaryProgress">
        <clip android:clipOrientation="horizontal" android:gravity="left">
            <shape android:shape="rectangle">
                <solid android:color="#332A3443" />
                <corners android:radius="1dp" />
            </shape>
        </clip>
    </item>

    <item android:id="@android:id/progress">
        <scale android:scaleWidth="100%" android:useLevel="true">
            <shape android:shape="rectangle">
                <gradient
                    android:angle="0"
                    android:startColor="#FF7C3AED"
                    android:centerColor="#FFA970FF"
                    android:endColor="#FF7C3AED"
                    android:type="linear" />
                <size android:height="4dp" />
                <corners android:radius="1dp" />
            </shape>
        </scale>
    </item>
</layer-list>
