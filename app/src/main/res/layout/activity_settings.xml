<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_product_shell"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_product_appbar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="12dp">

            <Button
                android:id="@+id/btnBack"
                style="@style/PButtonUtility"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:minHeight="0dp"
                android:text="@string/settings_back"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="end"
                    android:text="@string/settings_control_center"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:gravity="end"
                    android:text="@string/settings_control_center_subtitle"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>


        <TextView
            android:id="@+id/tvInterface"
            style="@style/CategoryTitle"
            android:text="@string/settings_interface" />

        <LinearLayout
            android:id="@+id/layInterface"
            style="@style/CategoryPanel"
            android:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/settings_language_title"
                android:textColor="@color/text_primary"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif"
                android:text="@string/settings_language_subtitle"
                android:textColor="@color/text_muted"
                android:textSize="10sp" />

            <RadioGroup
                android:id="@+id/radioLanguageGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/radioLanguageEnglish"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:fontFamily="sans-serif"
                    android:text="@string/settings_language_english"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />

                <RadioButton
                    android:id="@+id/radioLanguagePortuguese"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:fontFamily="sans-serif"
                    android:text="@string/settings_language_portuguese_brazil"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />
            </RadioGroup>
        </LinearLayout>

        <TextView
            android:id="@+id/tvSecBlock"
            style="@style/CategoryTitle"
            android:text="@string/settings_access_sensors" />

        <LinearLayout
            android:id="@+id/laySecBlock"
            style="@style/CategoryPanel"
            android:visibility="visible">

            <Button
                android:id="@+id/btnSetPassword"
                style="@style/PButton"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_local_password" />

            <Switch
                android:id="@+id/switchAppLock"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:fontFamily="sans-serif"
                android:text="@string/settings_app_lock"
                android:textColor="@color/text_primary" />

            <Switch
                android:id="@+id/switchBiometric"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:fontFamily="sans-serif"
                android:text="@string/settings_biometrics"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btnSensorOff"
                style="@style/PButton"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_sensor_off_guide" />

            <Button
                android:id="@+id/btnDisableUsb"
                style="@style/PButtonDanger"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:minHeight="0dp"
                android:text="@string/settings_disable_adb" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvNetwork"
            style="@style/CategoryTitle"
            android:text="@string/settings_network_safe_zone" />

        <LinearLayout
            android:id="@+id/layNetwork"
            style="@style/CategoryPanel"
            android:visibility="gone">

            <Switch
                android:id="@+id/switchAutoBlockWifi"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:fontFamily="sans-serif"
                android:text="@string/settings_block_unknown_network"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btnAddSafeWifi"
                style="@style/PButton"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_save_wifi" />

            <Button
                android:id="@+id/btnViewSafeWifis"
                style="@style/PButtonUtility"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_saved_networks" />

            <Button
                android:id="@+id/btnMacRandom"
                style="@style/PButton"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="8dp"
                android:minHeight="0dp"
                android:text="@string/settings_randomize_mac" />

            <Switch
                android:id="@+id/switchAutoGeofence"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:fontFamily="sans-serif"
                android:text="@string/settings_block_outside_safe_zone"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btnManageGeofences"
                style="@style/PButtonUtility"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_safe_zones" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPolicy"
            style="@style/CategoryTitle"
            android:text="@string/settings_automatic_policies" />

        <LinearLayout
            android:id="@+id/layPolicy"
            style="@style/CategoryPanel"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvTempReleaseStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_product_readout"
                android:fontFamily="monospace"
                android:padding="9dp"
                android:text="@string/settings_no_temp_release"
                android:textColor="@color/text_dim"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnUseCameraNow"
                style="@style/PButtonPrimary"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_use_camera_now" />

            <Button
                android:id="@+id/btnCancelTempRelease"
                style="@style/PButtonUtility"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="8dp"
                android:minHeight="0dp"
                android:text="@string/settings_cancel_release" />

            <Switch
                android:id="@+id/switchScheduleBlock"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:fontFamily="sans-serif"
                android:text="@string/settings_schedule_block"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btnScheduleWindow"
                style="@style/PButton"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="8dp"
                android:minHeight="0dp"
                android:text="@string/settings_define_window" />

            <Switch
                android:id="@+id/switchCallBlock"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:fontFamily="sans-serif"
                android:text="@string/settings_block_during_calls"
                android:textColor="@color/text_primary" />

            <Switch
                android:id="@+id/switchWhitelistRelease"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:fontFamily="sans-serif"
                android:text="@string/settings_release_trusted_apps"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btnAddTrustedApp"
                style="@style/PButton"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_add_app" />

            <Button
                android:id="@+id/btnViewTrustedApps"
                style="@style/PButtonUtility"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:minHeight="0dp"
                android:text="@string/settings_trusted_apps" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvPanic"
            style="@style/CategoryTitle"
            android:text="@string/settings_panic_wipe" />

        <LinearLayout
            android:id="@+id/layPanic"
            style="@style/CategoryPanel"
            android:background="@drawable/bg_product_danger_zone"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_product_notice_warning"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="2dp"
                android:padding="10dp"
                android:text="@string/settings_wipe_notice"
                android:textColor="@color/status_yellow"
                android:textSize="11sp" />

            <Switch
                android:id="@+id/switchRemoteWipe"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:fontFamily="sans-serif"
                android:text="@string/settings_remote_wipe_sms"
                android:textColor="@color/text_primary" />

            <EditText
                android:id="@+id/etWipeCode"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="8dp"
                android:background="@drawable/bg_product_readout"
                android:fontFamily="sans-serif"
                android:hint="@string/settings_wipe_code_hint"
                android:inputType="textPassword"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_dim" />

            <Switch
                android:id="@+id/switchPanicSms"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:fontFamily="sans-serif"
                android:text="@string/settings_panic_sms"
                android:textColor="@color/text_primary" />

            <EditText
                android:id="@+id/etPanicNumber"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_product_readout"
                android:fontFamily="sans-serif"
                android:hint="@string/settings_authorized_number_hint"
                android:inputType="phone"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_dim" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvRoot"
            style="@style/CategoryTitle"
            android:text="@string/settings_root_services" />

        <LinearLayout
            android:id="@+id/layRoot"
            style="@style/CategoryPanel"
            android:visibility="gone">

            <Switch
                android:id="@+id/switchRootMode"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:fontFamily="sans-serif"
                android:text="@string/settings_root_mode"
                android:textColor="@color/text_primary" />

            <Button
                android:id="@+id/btnTestRoot"
                style="@style/PButton"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_test_root" />

            <Button
                android:id="@+id/btnOpenTermux"
                style="@style/PButtonUtility"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:minHeight="0dp"
                android:text="@string/settings_open_termux" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTools"
            style="@style/CategoryTitle"
            android:text="@string/settings_tools_logs" />

        <LinearLayout
            android:id="@+id/layTools"
            style="@style/CategoryPanel"
            android:visibility="gone">

            <Button
                android:id="@+id/btnReapply"
                style="@style/PButton"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_reapply_protection" />

            <Button
                android:id="@+id/btnAccessibility"
                style="@style/PButton"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_accessibility" />

            <Button
                android:id="@+id/btnIntegrity"
                style="@style/PButton"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_integrity" />

            <Button
                android:id="@+id/btnViewLogs"
                style="@style/PButtonUtility"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/main_logs" />

            <Button
                android:id="@+id/btnExportLogs"
                style="@style/PButtonUtility"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_export_logs" />

            <Button
                android:id="@+id/btnClearLogs"
                style="@style/PButtonDanger"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="8dp"
                android:minHeight="0dp"
                android:text="@string/settings_clear_logs" />

            <Button
                android:id="@+id/btnGitHub"
                style="@style/PButtonUtility"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:layout_marginBottom="6dp"
                android:minHeight="0dp"
                android:text="@string/settings_github_psecurity" />

            <Button
                android:id="@+id/btnTikTok"
                style="@style/PButtonUtility"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:minHeight="0dp"
                android:text="@string/settings_tiktok_peeksecurity" />
        </LinearLayout>

        <!-- Ethical support footer: optional, transparent and non-invasive. -->
        <LinearLayout
            android:id="@+id/laySupportFooterSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_product_section"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="1dp"
                android:text="@string/support_footer_text"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnSupportProjectSettings"
                style="@style/PButtonUtility"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:minHeight="0dp"
                android:text="@string/support_project_button"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
