<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_control_shell"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="18dp">

        <!-- App bar: compact, product-like, no hero treatment -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_control_appbar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/app_name"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:fontFamily="sans-serif"
                    android:text="@string/main_device_protection_subtitle"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvRootStatus"
                android:layout_width="wrap_content"
                android:layout_height="26dp"
                android:background="@drawable/bg_control_badge_warning"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="@string/status_fallback"
                android:textColor="@color/status_yellow"
                android:textSize="10sp" />

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/settings_content_description"
                android:src="@drawable/ic_settings"
                android:tint="@color/text_dim" />
        </LinearLayout>

        <!-- Raw status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_control_status"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="9dp"
                android:background="@drawable/bg_status_dot" />

            <TextView
                android:id="@+id/tvProtectionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0"
                android:text="@string/status_standby_waiting_command"
                android:textColor="@color/text_dim"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Controls: closer to real settings/admin panels, not dashboard cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_control_section_focus"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="34dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/main_protection_controls"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_control_separator" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_control_row_highlight"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/main_apply_protection"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="@string/main_all_critical_sensors"
                        android:textColor="@color/text_muted"
                        android:textSize="10sp" />
                </LinearLayout>

                <Switch
                    android:id="@+id/switchBlockAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textOff=""
                    android:textOn="" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_control_separator" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_control_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/main_camera"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switchCamera"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textOff=""
                    android:textOn="" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_control_separator" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_control_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/main_microphone"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switchMicrophone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textOff=""
                    android:textOn="" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_control_separator" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_control_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/main_location"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switchLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textOff=""
                    android:textOn="" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_control_separator" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_control_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/main_bluetooth"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switchBluetooth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textOff=""
                    android:textOn="" />
            </LinearLayout>
        </LinearLayout>

        <!-- Readiness -->
        <LinearLayout
            android:id="@+id/panelPermissionCenter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_control_section"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/main_operational_status"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <Button
                    android:id="@+id/btnSetupPermissions"
                    style="@style/PButtonPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:minHeight="0dp"
                    android:text="@string/main_configure"
                    android:textSize="11sp" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_control_separator" />

            <TextView
                android:id="@+id/tvPermissionSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:paddingStart="12dp"
                android:paddingTop="10dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp"
                android:text="@string/status_checking"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_control_readout"
                android:orientation="vertical"
                android:padding="9dp">

                <TextView
                    android:id="@+id/tvAdminStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="monospace"
                    android:text="@string/main_device_admin_status"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvRuntimeStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="monospace"
                    android:text="@string/main_runtime_status"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvOverlayStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="monospace"
                    android:text="@string/main_overlay_status"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvBatteryStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:fontFamily="monospace"
                    android:text="@string/main_battery_status"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvAccessibilityStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="@string/main_accessibility_status"
                    android:textColor="@color/text_dim"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Local actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_control_section"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif-medium"
                android:text="@string/main_local_actions"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnLock"
                    style="@style/PButtonUtility"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:text="@string/main_lock"
                    android:textSize="11sp" />

                <Button
                    android:id="@+id/btnLogs"
                    style="@style/PButtonUtility"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:text="@string/main_logs"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Sensitive action is isolated, not mixed with normal commands. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_control_danger_section"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/main_sensitive_zone"
                android:textColor="@color/status_red"
                android:textSize="12sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="sans-serif"
                android:text="@string/main_sensitive_zone_notice"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnPanic"
                style="@style/PButtonDanger"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:minHeight="0dp"
                android:text="@string/main_panic_mode"
                android:textSize="11sp" />
        </LinearLayout>


        <!-- Ethical support footer: optional, transparent and non-invasive. -->
        <LinearLayout
            android:id="@+id/laySupportFooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_product_section"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:lineSpacingExtra="1dp"
                android:text="@string/support_footer_text"
                android:textColor="@color/text_muted"
                android:textSize="11sp" />

            <Button
                android:id="@+id/btnSupportProject"
                style="@style/PButtonUtility"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="8dp"
                android:minHeight="0dp"
                android:text="@string/support_project_button"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
